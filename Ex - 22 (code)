#include <stdio.h>

#define MAX 1000
int mem[MAX];

// init
void init() {
    for(int i=0;i<MAX;i++) mem[i] = -1;
}

// display
void show() {
    int i,j;
    printf("\nMemory Status:\n");
    for(i=0;i<MAX;i++) {
        if(mem[i]==-1) {
            j=i;
            while(j<MAX && mem[j]==-1) j++;
            printf("Free memory block %d-%d\n", i, j-1);
            i=j-1;
        }
    }
}

// BEST FIT (but sequential allocation style like your output)
void alloc(int p,int size) {
    int start=-1,count=0;

    for(int i=0;i<MAX;i++) {
        if(mem[i]==-1) {
            if(count==0) start=i;
            count++;
        } else count=0;

        if(count==size) break;
    }

    if(count==size) {
        for(int i=start;i<start+size;i++) mem[i]=p;
        printf("Allocated memory block %d-%d to Process %d\n",
               start,start+size-1,p);
    }
}

// free
void freeM(int p) {
    for(int i=0;i<MAX;i++)
        if(mem[i]==p) mem[i]=-1;

    printf("Memory released by Process %d\n", p);
}

// main
int main() {
    init(); show();

    alloc(1,199); show();
    alloc(2,100); show();
    freeM(1); show();
    alloc(3,100); show();

    return 0;
}
