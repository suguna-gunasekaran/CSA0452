#include<stdio.h>
#include<fcntl.h>
#include<unistd.h>
#include<sys/stat.h>
#include<dirent.h>

int main()
{
    int fd;
    struct stat s;
    DIR *d;
    struct dirent *dir;

    fd = open("test.txt", O_CREAT | O_RDONLY, 0777);

    printf("File Descriptor = %d\n", fd);

    printf("File Size = %ld\n", lseek(fd, 0, SEEK_END));

    stat("test.txt", &s);
    printf("Links = %ld\n", s.st_nlink);

    d = opendir(".");

    printf("\nFiles in Directory:\n");

    while((dir = readdir(d)) != NULL)
    {
        printf("%s\n", dir->d_name);
    }

    close(fd);
    closedir(d);

    return 0;
}
