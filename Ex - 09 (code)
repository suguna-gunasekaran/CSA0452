#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <sys/wait.h>
#include <string.h>

int main() {
    int shmid;
    char *ptr;

    shmid = shmget(IPC_PRIVATE, 1024, 0666 | IPC_CREAT);
    ptr = (char*)shmat(shmid, NULL, 0);

    if (fork() > 0) {
        strcpy(ptr, "Hello from Parent Process!");
        printf("Parent wrote: %s\n", ptr);
        wait(NULL);
    } else {
        sleep(1);
        printf("Child read: %s\n", ptr);
    }

    shmdt(ptr);
    shmctl(shmid, IPC_RMID, NULL);
}
