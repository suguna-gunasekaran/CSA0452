#include <stdio.h>

int main() {
    int n, bt[10], at[10], pr[10];
    int wt[10]={0}, tat[10]={0}, rt[10];
    int i, time = 0, completed = 0, min, shortest;
    int finish_time;
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter Arrival Time:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &at[i]);

    printf("Enter Burst Time:\n");
    for(i = 0; i < n; i++){
        scanf("%d", &bt[i]);
        rt[i] = bt[i]; // remaining time
    }

    printf("Enter Priority:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &pr[i]);

    while(completed != n) {
        min = 9999;
        shortest = -1;

        for(i = 0; i < n; i++) {
            if(at[i] <= time && rt[i] > 0 && pr[i] < min) {
                min = pr[i];
                shortest = i;
            }
        }

        if(shortest == -1) {
            time++;
            continue;
        }

        rt[shortest]--;
        time++;

        if(rt[shortest] == 0) {
            completed++;
            finish_time = time;

            wt[shortest] = finish_time - bt[shortest] - at[shortest];
            if(wt[shortest] < 0)
                wt[shortest] = 0;

            tat[shortest] = bt[shortest] + wt[shortest];

            avg_wt += wt[shortest];
            avg_tat += tat[shortest];
        }
    }

    printf("\nProcess\tAT\tBT\tPriority\tWT\tTAT\n");
    for(i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t\t%d\t%d\n",
               i+1, at[i], bt[i], pr[i], wt[i], tat[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt/n);
    printf("\nAverage Turnaround Time = %.2f", avg_tat/n);

    return 0;
}
