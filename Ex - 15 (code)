#include <stdio.h>
#include <string.h>

#define MAX_USERS 10
#define MAX_FILES 20

struct User {
    char uname[50];
    char files[MAX_FILES][50];
    int fileCount;
};

struct User users[MAX_USERS];
int userCount = 0;

void createUser() {
    char name[50];
    printf("Enter user name: ");
    scanf("%s", name);

    for(int i = 0; i < userCount; i++) {
        if(strcmp(users[i].uname, name) == 0) {
            printf("User already exists!\n");
            return;
        }
    }

    strcpy(users[userCount].uname, name);
    users[userCount].fileCount = 0;
    userCount++;
    printf("User created successfully!\n");
}

void createFile() {
    char uname[50], fname[50];
    printf("Enter user name: ");
    scanf("%s", uname);

    for(int i = 0; i < userCount; i++) {
        if(strcmp(users[i].uname, uname) == 0) {
            printf("Enter file name: ");
            scanf("%s", fname);

            for(int j = 0; j < users[i].fileCount; j++) {
                if(strcmp(users[i].files[j], fname) == 0) {
                    printf("File already exists for this user!\n");
                    return;
                }
            }

            strcpy(users[i].files[users[i].fileCount], fname);
            users[i].fileCount++;
            printf("File created successfully!\n");
            return;
        }
    }

    printf("User not found!\n");
}

void display() {
    if(userCount == 0) {
        printf("No users available!\n");
        return;
    }

    for(int i = 0; i < userCount; i++) {
        printf("\nUser: %s\n", users[i].uname);
        if(users[i].fileCount == 0) {
            printf("  No files\n");
        } else {
            for(int j = 0; j < users[i].fileCount; j++) {
                printf("  %s\n", users[i].files[j]);
            }
        }
    }
}

int main() {
    int choice;

    while(1) {
        printf("\n--- Two Level Directory ---\n");
        printf("1. Create User\n");
        printf("2. Create File\n");
        printf("3. Display Directory\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1: createUser(); break;
            case 2: createFile(); break;
            case 3: display(); break;
            case 4: return 0;
            default: printf("Invalid choice!\n");
        }
    }
}
