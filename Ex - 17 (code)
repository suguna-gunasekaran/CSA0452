#include <stdio.h>

int main() {
    int i, j;

    int alloc[5][3] = {
        {0,1,0},{2,0,0},{3,0,2},{2,1,1},{0,0,2}
    };

    int max[5][3] = {
        {7,5,3},{3,2,2},{9,0,2},{2,2,2},{4,3,3}
    };

    int avail[3] = {3,3,2};
    int need[5][3];

    int p, req[3];

    // Calculate need
    for(i=0;i<5;i++)
        for(j=0;j<3;j++)
            need[i][j] = max[i][j] - alloc[i][j];

    printf("Enter process number (0 to 4): ");
    scanf("%d",&p);

    printf("Enter request (3 values): ");
    for(i=0;i<3;i++)
        scanf("%d",&req[i]);

    // Check request <= need and available
    for(i=0;i<3;i++) {
        if(req[i] > need[p][i] || req[i] > avail[i]) {
            printf("Request denied.\n");
            return 0;
        }
    }

    // Temporary allocation
    for(i=0;i<3;i++) {
        avail[i] -= req[i];
        alloc[p][i] += req[i];
        need[p][i] -= req[i];
    }

    int finish[5]={0}, safe[5], count=0;

    while(count < 5) {
        int found = 0;

        for(i=0;i<5;i++) {
            if(!finish[i]) {
                for(j=0;j<3;j++)
                    if(need[i][j] > avail[j])
                        break;

                if(j==3) {
                    for(int k=0;k<3;k++)
                        avail[k] += alloc[i][k];

                    safe[count++] = i;
                    finish[i]=1;
                    found = 1;
                }
            }
        }

        if(!found) {
            printf("Request denied. System is not in safe state.\n");
            return 0;
        }
    }

    printf("Request granted. Safe sequence: ");
    for(i=0;i<5;i++)
        printf("P%d ", safe[i]);

    return 0;
}
