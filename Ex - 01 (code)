#include <stdio.h>
#include <unistd.h>
int main() {
    pid_t pid;
    pid = fork(); // Creation of new process
    if (pid < 0) {
        printf("Process creation has failed\n");
    }
    else if (pid == 0) {
        // Child process
        printf("Child Process\n");
        printf("PID: %d\n", getpid());
        printf("Parent PID: %d\n", getppid());
    }
    else {
        // Parent process
        printf("Parent Process\n");
        printf("PID: %d\n", getpid());
        printf("Child PID: %d\n", pid);
    }
    return 0;
}
